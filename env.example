# -----------------------------------------------------------------------------
# Application BASE URL
# For production: https://www.whataisle.com
# For local development: http://localhost:3000
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Root domain for per-store subdomains (<handle>.<root-domain>)
# For production: whataisle.com
# For local development: localhost (stores resolve as <handle>.localhost:3000)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ROOT_DOMAIN="localhost"

# -----------------------------------------------------------------------------
# Database (Postgres with pgvector; local dev: docker compose up -d)
# -----------------------------------------------------------------------------
DATABASE_URL="postgres://whataisle:whataisle@localhost:5433/whataisle"

# -----------------------------------------------------------------------------
# Better Auth
# Generate a random string for the secret key using `openssl rand -base64 32`
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=""

# -----------------------------------------------------------------------------
# Google OAuth (owner login; optional in local dev — email/password works)
# Get client information from https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Mail
# MAIL_PROVIDER=smtp for local dev (Mailpit UI at http://localhost:8025)
# MAIL_PROVIDER=resend (default) for production, with RESEND_API_KEY set
# -----------------------------------------------------------------------------
MAIL_PROVIDER="smtp"
SMTP_HOST="localhost"
SMTP_PORT="1025"
RESEND_API_KEY=""

# -----------------------------------------------------------------------------
# AI (Qwen via DashScope International / Alibaba Cloud Model Studio)
# Get an API key from the Model Studio console (Singapore region).
# Model ids are optional overrides — defaults live in src/ai/models.ts.
# -----------------------------------------------------------------------------
DASHSCOPE_API_KEY=""
# DASHSCOPE_BASE_URL="https://dashscope-intl.aliyuncs.com"
# QWEN_MODEL="qwen3.5-flash"
# QWEN_VISION_MODEL="qwen3-vl-plus"
# QWEN_ASR_MODEL="qwen3-asr-flash"
# QWEN_EMBED_MODEL="text-embedding-v4"
# Force deterministic stub recognition (offline dev / CI, no real AI calls).
# Stubs BOTH providers: DashScope (search/aliases/embeddings) and OpenRouter
# (shelf detection). Leave unset once real keys are available.
AI_STUB="false"

# -----------------------------------------------------------------------------
# AI shelf detection (OpenRouter — rows-hd pipeline ported from
# whataisle-readshelf: row detect + HD band detect + grid readout, plus the
# landing try-out's precheck gate). Without this key the scan runs in stub
# mode even when DashScope is configured.
# Model ids and tunables are optional overrides — defaults in src/ai/scan/config.ts.
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=""
# OPENROUTER_SCAN_MODEL="google/gemini-3.5-flash"
# OPENROUTER_ROW_MODEL="google/gemini-3.5-flash"
# OPENROUTER_READOUT_MODEL="google/gemini-3.5-flash"
# OPENROUTER_PRECHECK_MODEL="google/gemini-3.5-flash-lite"
# OPENROUTER_MAX_CONCURRENT="32"
# SCAN_BAND_CONCURRENCY="6"
# SCAN_MAX_BAND_SIDE="3072"
# SCAN_GRID_K="6"
# SCAN_GRID_CONCURRENCY="6"

# -----------------------------------------------------------------------------
# Storage
# Local dev: files are written to STORAGE_LOCAL_DIR (default ./.storage)
# Production: "gcs" (Google Cloud Storage via ADC — needs GOOGLE_CLOUD_PROJECT
# and STORAGE_BUCKET_NAME only) or "s3" (S3-compatible, e.g. R2)
# -----------------------------------------------------------------------------
STORAGE_PROVIDER="local"
STORAGE_LOCAL_DIR="./.storage"
# Required only for STORAGE_PROVIDER="gcs" (ADC).
GOOGLE_CLOUD_PROJECT=""
STORAGE_REGION="auto"
STORAGE_BUCKET_NAME=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_ENDPOINT=""
STORAGE_PUBLIC_URL=""

# -----------------------------------------------------------------------------
# Staff PIN cookies (HMAC signing secret)
# Generate with `openssl rand -base64 32`
# -----------------------------------------------------------------------------
STAFF_COOKIE_SECRET=""

# -----------------------------------------------------------------------------
# Payment (Stripe) — dormant; billing is defined separately and not yet enabled
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PAYMENT_PROVIDER="stripe"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=""
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=""
NEXT_PUBLIC_STRIPE_PRICE_LIFETIME=""
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_BASIC=""
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_STANDARD=""
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_PREMIUM=""
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_ENTERPRISE=""

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
DISABLE_IMAGE_OPTIMIZATION=false
# Set to "true" ONLY when the app runs behind a GCP external HTTPS load
# balancer AND Cloud Run ingress is restricted to it — client IPs are then
# taken from the second-to-last x-forwarded-for entry (see src/lib/client-ip.ts)
TRUST_GCP_LOAD_BALANCER=false
# Allow public email signup in production (default: invite-only)
PUBLIC_SIGNUP_ENABLED=false
# Ops inbox that receives new store walkthrough videos (signed download link)
VIDEO_NOTIFY_EMAIL=""
NEXT_PUBLIC_DEMO_WEBSITE=false
# Captcha (Cloudflare Turnstile; only used when demo mode is on)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
