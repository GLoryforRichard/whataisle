# Shared configuration for WhatAisle GCP deployment scripts.
# Source this from each script: . "$(dirname "$0")/config.env"

export PROJECT_ID="whataisle-prod"
export REGION="us-central1"

export SERVICE_NAME="whataisle"
export MIGRATE_JOB_NAME="whataisle-migrate"
export AR_REPO="whataisle"
export RUNTIME_SA_NAME="whataisle-run"
export RUNTIME_SA="${RUNTIME_SA_NAME}@${PROJECT_ID}.iam.gserviceaccount.com"

export BUCKET_NAME="${PROJECT_ID}-whataisle-media"

export SQL_INSTANCE="whataisle-pg"
export SQL_TIER="db-g1-small"
export DB_NAME="whataisle"
export DB_USER="whataisle"

export ROOT_DOMAIN="whataisle.com"
export BASE_URL="https://www.${ROOT_DOMAIN}"

export IMAGE="${REGION}-docker.pkg.dev/${PROJECT_ID}/${AR_REPO}/app"
export MIGRATE_IMAGE="${REGION}-docker.pkg.dev/${PROJECT_ID}/${AR_REPO}/migrate"
